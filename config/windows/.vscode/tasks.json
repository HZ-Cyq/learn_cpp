{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Create bin directory",
            "command": "New-Item",
            "args": [
                "-ItemType",
                "Directory",
                "-Force",
                "${workspaceFolder}\\bin"
            ],
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Od",
                "/MDd",
                "/Fe${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe",
                "/Fo${workspaceFolder}\\bin\\",
                "/Fd${workspaceFolder}\\bin\\",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "Create bin directory"
        }
    ]
}